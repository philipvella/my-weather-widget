# Required
OPENWEATHERMAP_API_KEY=your_openweather_api_key_here
GITHUB_REPO_URL=https://github.com/your-user/your-repo

# Upstash Redis (replaces deprecated Vercel KV)
# Add the Upstash Redis integration from the Vercel Marketplace, then run:
#   vercel env pull .env.local
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
