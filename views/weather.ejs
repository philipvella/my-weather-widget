<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= city %><% if (country) { %>, <%= country %><% } %> — Weather</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="m-0 bg-gradient-to-br <%= bgGradient %> min-h-screen overflow-y-auto">
  <div class="fixed bottom-1 right-1 z-20 flex items-center gap-1">
    <% if (githubRepoUrl) { %>
      <div class="relative group">
        <a
          href="<%= githubRepoUrl %>"
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-full bg-black/25 border border-white/30 p-1.5 text-white/95 no-underline hover:bg-black/35 flex items-center"
          aria-label="Open GitHub repository"
        ><%- include('partials/icons/github', { className: 'w-3.5 h-3.5' }) %></a>
        <span class="pointer-events-none absolute bottom-full right-0 mb-1.5 whitespace-nowrap rounded bg-black/70 px-2 py-1 text-xs text-white opacity-0 transition-opacity group-hover:opacity-100 group-focus-within:opacity-100">
          GitHub repo
        </span>
      </div>
    <% } %>
    <div class="relative group">
      <a
        href=""
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full bg-black/25 border border-white/30 p-1.5 text-white/95 no-underline hover:bg-black/35 flex items-center"
        aria-label="Open weather in a new window"
      ><%- include('partials/icons/open-in-new', { className: 'w-3.5 h-3.5' }) %></a>
      <span class="pointer-events-none absolute bottom-full right-0 mb-1.5 whitespace-nowrap rounded bg-black/70 px-2 py-1 text-xs text-white opacity-0 transition-opacity group-hover:opacity-100 group-focus-within:opacity-100">
        Open in new tab
      </span>
    </div>
  </div>
  <main
    role="main"
    class="min-h-screen flex flex-col items-center justify-start p-3 sm:p-6 gap-2 <%= textColor %> landscape:flex-row landscape:items-center landscape:justify-between landscape:gap-1 landscape:py-1 landscape:px-2 landscape:overflow-x-auto"
  >

    <!-- Location -->
    <header class="w-full text-center mb-2 landscape:mb-0 landscape:text-left landscape:flex-1 landscape:min-w-0">
      <h1 class="text-xl sm:text-3xl landscape:text-sm lg:text-3xl font-semibold tracking-wide leading-tight truncate">
        <%= city %><% if (country) { %>, <span class="opacity-70"><%= country %></span><% } %>
      </h1>
      <% if (selectedDateLabel) { %>
        <p class="text-xs sm:text-sm mt-1 opacity-70 truncate">
          <span class="hidden sm:inline"><% if (forecastMode) { %>Forecast for<% } else { %>Date<% } %>: </span><span class="font-medium"><%= selectedDateLabel %></span>
        </p>
      <% } %>
      <% if (infoMessage) { %>
        <p class="text-sm m-0 px-2 py-1 rounded-lg bg-black/20 border border-white/20 max-w-md mx-auto text-center landscape:mx-0 landscape:text-left"><%= infoMessage %></p>
      <% } %>
    </header>

    <!-- Icon + temperature -->
    <section aria-label="Current temperature" class="flex flex-col items-center mb-2 landscape:mb-0 landscape:flex-row landscape:items-center landscape:gap-1 landscape:flex-1 landscape:min-w-0">
      <img
        src="https://openweathermap.org/img/wn/<%= icon %>@2x.png"
        alt="<%= description %>"
        class="drop-shadow-lg w-20 h-20 sm:w-28 sm:h-28 landscape:w-10 landscape:h-10"
      />
      <div class="text-5xl sm:text-7xl landscape:text-2xl font-thin tracking-tighter leading-none mt-1 landscape:mt-0 whitespace-nowrap">
        <%= temperature %><span class="text-2xl sm:text-4xl landscape:text-sm align-top mt-2 inline-block"><%= unitSymbol %></span>
      </div>
      <p class="capitalize mt-1 landscape:mt-0 text-base sm:text-lg font-light opacity-80 hidden sm:block md:landscape:hidden lg:landscape:block"><%= description %></p>
      <p class="text-sm mt-1 landscape:mt-0 opacity-60 hidden sm:block md:landscape:hidden lg:landscape:block">Feels like <%= feelsLike %><%= unitSymbol %></p>
    </section>

    <!-- Extra stats -->
    <section
      aria-label="Weather details"
      class="w-full max-w-3xl grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-6 mt-1 text-center landscape:mt-0 landscape:flex landscape:flex-nowrap landscape:justify-end landscape:items-center landscape:gap-1 landscape:flex-[1.5]"
    >
      <div class="landscape:min-w-14">
        <p class="text-xs uppercase tracking-widest opacity-50 mb-1 flex items-center justify-center gap-1">
          <span class="sr-only">Humidity</span>
          <span class="relative group sm:hidden inline-flex">
            <%- include('partials/icons/humidity', { className: 'inline-flex w-3 h-3' }) %>
            <span class="pointer-events-none absolute bottom-full right-0 mb-1.5 whitespace-nowrap rounded bg-black/70 px-2 py-1 text-xs text-white normal-case tracking-normal opacity-0 transition-opacity group-hover:opacity-100 group-focus-within:opacity-100">
              Humidity
            </span>
          </span>
          <span class="hidden sm:inline">Humidity</span>
        </p>
        <p class="text-base sm:text-xl landscape:text-xs font-medium"><%= humidity %>%</p>
      </div>
      <div class="landscape:min-w-14">
        <p class="text-xs uppercase tracking-widest opacity-50 mb-1 flex items-center justify-center gap-1">
          <span class="sr-only">Wind</span>
          <span class="relative group sm:hidden inline-flex">
            <%- include('partials/icons/wind', { className: 'inline-flex w-3 h-3' }) %>
            <span class="pointer-events-none absolute bottom-full right-0 mb-1.5 whitespace-nowrap rounded bg-black/70 px-2 py-1 text-xs text-white normal-case tracking-normal opacity-0 transition-opacity group-hover:opacity-100 group-focus-within:opacity-100">
              Wind
            </span>
          </span>
          <span class="hidden sm:inline">Wind</span>
        </p>
        <p class="text-base sm:text-xl landscape:text-xs font-medium"><%= windSpeed %> <span class="text-xs font-normal"><%= windUnit %></span></p>
      </div>
      <div class="landscape:min-w-14">
        <p class="text-xs uppercase tracking-widest opacity-50 mb-1 flex items-center justify-center gap-1">
          <span class="sr-only">Precip chance</span>
          <span class="relative group sm:hidden inline-flex">
            <%- include('partials/icons/precip-chance', { className: 'inline-flex w-3 h-3' }) %>
            <span class="pointer-events-none absolute bottom-full right-0 mb-1.5 whitespace-nowrap rounded bg-black/70 px-2 py-1 text-xs text-white normal-case tracking-normal opacity-0 transition-opacity group-hover:opacity-100 group-focus-within:opacity-100">
              Precip chance
            </span>
          </span>
          <span class="hidden sm:inline">Precip chance</span>
        </p>
        <p class="text-base sm:text-xl landscape:text-xs font-medium">
          <% if (precipitationChance === null) { %>
            --
          <% } else { %>
            <%= precipitationChance %>%
          <% } %>
        </p>
      </div>
      <div class="landscape:min-w-14">
        <p class="text-xs uppercase tracking-widest opacity-50 mb-1 flex items-center justify-center gap-1">
          <span class="sr-only">Precip amount</span>
          <span class="relative group sm:hidden inline-flex">
            <%- include('partials/icons/precip-amount', { className: 'inline-flex w-3 h-3' }) %>
            <span class="pointer-events-none absolute bottom-full right-0 mb-1.5 whitespace-nowrap rounded bg-black/70 px-2 py-1 text-xs text-white normal-case tracking-normal opacity-0 transition-opacity group-hover:opacity-100 group-focus-within:opacity-100">
              Precip amount
            </span>
          </span>
          <span class="hidden sm:inline">Precip amount</span>
        </p>
        <p class="text-base sm:text-xl landscape:text-xs font-medium"><%= precipitationAmountMm.toFixed(1) %> <span class="text-xs font-normal">mm</span></p>
      </div>
    </section>

  </main>
</body>
</html>

