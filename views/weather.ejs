<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= city %><% if (country) { %>, <%= country %><% } %> — Weather</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>* { box-sizing: border-box; } body { margin: 0; }</style>
</head>
<body class="bg-gradient-to-br <%= bgGradient %> min-h-screen">
  <main
    role="main"
    class="min-h-screen flex flex-col items-center justify-center p-6 <%= textColor %>"
  >

    <!-- Location -->
    <header class="text-center mb-4">
      <h1 class="text-3xl font-semibold tracking-wide">
        <%= city %><% if (country) { %>, <span class="opacity-70"><%= country %></span><% } %>
      </h1>
    </header>

    <!-- Icon + temperature -->
    <section aria-label="Current temperature" class="flex flex-col items-center mb-4">
      <img
        src="https://openweathermap.org/img/wn/<%= icon %>@2x.png"
        alt="<%= description %>"
        width="100"
        height="100"
        class="drop-shadow-lg"
      />
      <div class="text-7xl font-thin tracking-tighter leading-none mt-1">
        <%= temperature %><span class="text-4xl align-top mt-2 inline-block"><%= unitSymbol %></span>
      </div>
      <p class="capitalize mt-2 text-lg font-light opacity-80"><%= description %></p>
      <p class="text-sm mt-1 opacity-60">Feels like <%= feelsLike %><%= unitSymbol %></p>
    </section>

    <!-- Extra stats -->
    <section
      aria-label="Weather details"
      class="flex gap-10 mt-2 text-center"
    >
      <div>
        <p class="text-xs uppercase tracking-widest opacity-50 mb-1">Humidity</p>
        <p class="text-xl font-medium"><%= humidity %>%</p>
      </div>
      <div class="border-l border-current opacity-20 self-stretch"></div>
      <div>
        <p class="text-xs uppercase tracking-widest opacity-50 mb-1">Wind</p>
        <p class="text-xl font-medium"><%= windSpeed %> <span class="text-sm font-normal"><%= windUnit %></span></p>
      </div>
    </section>

  </main>
</body>
</html>

