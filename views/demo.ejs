<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Interactive demo page showing the weather widget embedded at common iframe sizes and layouts."
    />
    <title>Weather Widget — Demo</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link
      rel="preload"
      href="/css/style.css"
      as="style"
      onload="
        this.onload = null;
        this.rel = 'stylesheet';
      "
    />
    <noscript><link rel="stylesheet" href="/css/style.css" /></noscript>
  </head>
  <body class="bg-gray-950 text-gray-100 min-h-screen p-6 sm:p-10 font-sans">
    <div class="max-w-4xl mx-auto space-y-12">
      <header>
        <h1 class="text-2xl font-bold tracking-tight">Weather Widget — Embed Demo</h1>
        <p class="text-gray-400 mt-1 text-sm">
          Shows how the widget looks at common embed sizes. All iframes use the live widget from
          this server.
        </p>
      </header>

      <!-- Wide banner (Notion full-width embed) -->
      <section>
        <h2 class="text-sm uppercase tracking-widest text-gray-500 mb-2">
          Wide banner — 800 × 160
        </h2>
        <iframe
          src="/city/london"
          width="800"
          height="160"
          frameborder="0"
          class="rounded-lg overflow-hidden w-full max-w-3xl block"
          title="London weather — wide"
        ></iframe>
      </section>

      <!-- Compact strip (short landscape) -->
      <section>
        <h2 class="text-sm uppercase tracking-widest text-gray-500 mb-2">
          Compact strip — 388 × 100
        </h2>
        <iframe
          src="/city/paris"
          width="388"
          height="100"
          frameborder="0"
          class="rounded-lg overflow-hidden block"
          title="Paris weather — compact strip"
        ></iframe>
      </section>

      <!-- Square card -->
      <section>
        <h2 class="text-sm uppercase tracking-widest text-gray-500 mb-2">
          Square card — 300 × 300
        </h2>
        <iframe
          src="/city/tokyo"
          width="300"
          height="300"
          frameborder="0"
          class="rounded-lg overflow-hidden block"
          title="Tokyo weather — square"
        ></iframe>
      </section>

      <!-- Tall portrait (mobile column) -->
      <section>
        <h2 class="text-sm uppercase tracking-widest text-gray-500 mb-2">Portrait — 360 × 480</h2>
        <iframe
          src="/city/new york?units=imperial"
          width="360"
          height="480"
          frameborder="0"
          class="rounded-lg overflow-hidden block"
          title="New York weather — portrait"
        ></iframe>
      </section>

      <!-- Coordinates -->
      <section>
        <h2 class="text-sm uppercase tracking-widest text-gray-500 mb-2">
          Coordinates — 500 × 180
        </h2>
        <iframe
          src="/coordinates/48.8566/2.3522"
          width="500"
          height="180"
          frameborder="0"
          class="rounded-lg overflow-hidden block"
          title="Paris by coordinates"
        ></iframe>
      </section>

      <!-- Date range — click-to-shift explained -->
      <section>
        <h2 class="text-sm uppercase tracking-widest text-gray-500 mb-2">
          Date range — click to shift — 360 × 480
        </h2>
        <p class="text-gray-400 mt-1 mb-2 text-sm">
          All embeds above share the same 3-day window:
          <code class="text-gray-400">from=<%= from %></code> →
          <code class="text-gray-400">to=<%= to %></code>. Click any day chip inside the widget to
          shift the entire window forward to that day while keeping the 3-day span. The URL updates
          in place — no new tab.
        </p>
        <iframe
          src="/city/london?from=<%= from %>&to=<%= to %>"
          width="360"
          height="480"
          frameborder="0"
          class="rounded-lg overflow-hidden block"
          title="London weather — 3-day range, click to shift"
        ></iframe>
      </section>

      <footer class="text-xs text-gray-600 border-t border-gray-800 pt-4">
        Embed any route as an iframe. All query params (<code class="text-gray-400">units</code>,
        <code class="text-gray-400">date</code>, <code class="text-gray-400">from</code>, and
        <code class="text-gray-400">to</code>) work inside iframes too.
      </footer>
    </div>
  </body>
</html>
