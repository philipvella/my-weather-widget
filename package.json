{
  "name": "weather-widget",
  "version": "1.0.1",
  "description": "Server-side rendered weather widget for Notion embeds",
  "engines": {
    "node": ">=18.x"
  },
  "scripts": {
    "prepare": "husky",
    "build": "tailwindcss -i ./src/css/input.css -o ./public/css/style.css --minify",
    "build:css": "tailwindcss -i ./src/css/input.css -o ./public/css/style.css --minify",
    "dev:css": "tailwindcss -i ./src/css/input.css -o ./public/css/style.css --watch",
    "dev": "npm run build:css && nodemon api/index.js",
    "start": "node api/index.js",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,json,md,css,ejs}": "prettier --write"
  },
  "dependencies": {
    "@upstash/redis": "^1.37.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "ejs": "^3.1.10",
    "express": "^4.19.0",
    "express-rate-limit": "^7.3.0",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "nodemon": "^3.1.0",
    "prettier": "^3.6.2",
    "supertest": "^7.1.1",
    "tailwindcss": "^3.4.19",
    "vitest": "^3.2.4"
  }
}
